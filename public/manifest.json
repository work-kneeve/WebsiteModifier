{
  "manifest_version": 3,
  "name": "SiteMorph (Community Edition)",
  "version": "1.0.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open SiteMorph"
  },
  "background": {
    "service_worker": "background.js"
  }
}
